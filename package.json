{
  "name": "aiyoke",
  "version": "0.4.0",
  "description": "Deterministic, extensible AI harness compiler for Claude Code, ChatGPT/Codex, Grok/Grok Build, and OpenRouter.",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "license": "Apache-2.0",
  "author": "Ryan Pavlicek",
  "keywords": [
    "ai",
    "agents",
    "claude-code",
    "codex",
    "grok",
    "openrouter",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanpavlicek/aiyoke.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0",
  "bin": {
    "aiyoke": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./extension-sdk": {
      "types": "./dist/extension-sdk/index.d.ts",
      "import": "./dist/extension-sdk/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate:runtime-js": "pnpm build && node scripts/generate-javascript-runtime-templates.mjs --write && pnpm lint:fix",
    "check:runtime-js": "pnpm build && node scripts/generate-javascript-runtime-templates.mjs",
    "check:static": "pnpm lint && pnpm typecheck && pnpm architecture && pnpm test:docs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:runtimes": "pnpm build && node scripts/validate-runtime-fixtures.mjs",
    "test:frameworks": "pnpm build && node scripts/validate-framework-runtime-fixtures.mjs",
    "test:targets": "pnpm build && node scripts/validate-target-client-fixtures.mjs",
    "test:target-clients": "pnpm build && node scripts/validate-target-client-fixtures.mjs --native",
    "test:isolation-dist": "node scripts/validate-built-extension-isolation.mjs",
    "test:docs": "node scripts/validate-docs.mjs",
    "test:docs:external": "node --use-system-ca scripts/validate-docs.mjs --external",
    "test:package": "pnpm build && node scripts/validate-package.mjs",
    "security:audit": "pnpm audit --prod --audit-level high",
    "test:live": "pnpm build && node --use-system-ca --env-file-if-exists=.env scripts/live-provider-smoke.mjs",
    "architecture": "node scripts/check-architecture.mjs",
    "check": "pnpm check:static && pnpm test:coverage && pnpm check:runtime-js && pnpm test:isolation-dist",
    "dev": "tsx src/cli.ts",
    "prepack": "pnpm check"
  },
  "dependencies": {
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@biomejs/biome": "2.5.4",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "4.1.10",
    "fast-check": "4.9.0",
    "publint": "0.3.22",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
